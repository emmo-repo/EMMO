###  https://w3id.org/emmo#Pascal
:Pascal rdf:type owl:NamedIndividual ,
                 :EMMO_53bd0c90_41c3_46e2_8779_cd2a80f7e18b ,
                 :EMMO_e9ffc696_5228_4ff9_8a60_0f5e05e9931b ;
        :EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "Pa" ;
        skos:prefLabel "Pascal"@en ;
