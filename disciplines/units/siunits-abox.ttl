###  https://w3id.org/emmo#Newton
:Newton rdf:type owl:NamedIndividual ,
                 :EMMO_53e825d9_1a09_483c_baa7_37501ebfbe1c ,
                 :EMMO_e9ffc696_5228_4ff9_8a60_0f5e05e9931b ;
        :EMMO_daf7a9b7_18ef_4e73_9fb9_75adfd9800e8 "N" ;
        skos:prefLabel "Newton"@en ;
        schema:unitCode "NEW" ;
        :dbpediaReference "http://dbpedia.org/resource/Newton"^^xsd:anyURI ;
        :elucidation "SI unit for force."@en ;
        :iupacReference "https://doi.org/10.1351/goldbook.N04135" ;
        :note """The \"Newton\" is the SI unit of force. A force of one newton will accelerate a mass of one kilogram at the rate of one meter per second per second. The newton is named for Isaac Newton (1642-1727), the British mathematician, physicist, and natural philosopher. He was the first person to understand clearly the relationship between force (F), mass (m), and acceleration (a) expressed by the formula F = m·a.

-- QUDT"""@en ;
        :qudtReference "http://qudt.org/vocab/unit/N" ;
        :ucumCode "N" ;
        :wikipediaReference "http://en.wikipedia.org/wiki/Newton?oldid=488427661"^^xsd:anyURI .


