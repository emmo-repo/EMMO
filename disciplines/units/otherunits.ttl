        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e ;
    rdfs:isDefinedBy "http://qudt.org/2.1/vocab/unit" ;
    skos:prefLabel "Acre"@en ;
    emmo:elucidation """The acre is a unit of area in a number of different systems, including the imperial and U.S. customary systems. Its international symbol is ac. The most commonly used acres today are the international acre and, in the United States, the survey acre. The most common use of the acre is to measure tracts of land. One international acre is equal to 4046.8564224 square metres.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/AC" ;
    emmo:ucumCode "[acr_br]" ;
    emmo:unitSymbol "acre" ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Acre?oldid=495387342" .

emmo:AcreFoot a [ a owl:Restriction ;
            owl:hasValue 1.233482e+03 ;
            owl:onProperty emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf ],
        [ a owl:Restriction ;
            owl:hasValue 0e+00 ;
            owl:onProperty emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd ],
        emmo:EMMO_8246541a_f1f6_4d03_8bd7_fc6b76d17375,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_9141801c_c539_4c72_b423_8c74ff6b8f05 ;
    rdfs:isDefinedBy "http://qudt.org/2.1/vocab/unit" ;
    rdfs:seeAlso "http://www.oxfordreference.com/view/10.1093/acref/9780198605225.001.0001/acref-9780198605225-e-35" ;
    skos:altLabel "Acre Foot"@en ;
    skos:prefLabel "AcreFoot"@en ;
    emmo:elucidation """An acre-foot is a unit of volume commonly used in the United States in reference to large-scale water resources, such as reservoirs, aqueducts, canals, sewer flow capacity, and river flows. It is defined by the volume of one acre of surface area to a depth of one foot. Since the acre is defined as a chain by a furlong (66 ft × 660 ft) the acre-foot is exactly 43,560 cubic feet. For irrigation water, the volume of 1 ft × 1 ac = 43,560 ft³ (1,233.482 m³, 325,851 US gal).

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/AC-FT" ;
    emmo:ucumCode "[acr_br].[ft_i]" ;
    emmo:unitSymbol "ac⋅ft" ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Acre-foot" .

emmo:AmpereTurn a emmo:EMMO_08b308d4_31cd_4779_a784_aa92fc730f39,
        emmo:EMMO_15344998_4490_4b40_b242_c3d92e5cdc27,
