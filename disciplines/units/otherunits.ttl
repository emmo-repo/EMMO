        emmo:EMMO_b14d9be5_f81e_469b_abca_379c2e83feab ;
    rdfs:isDefinedBy "http://qudt.org/2.1/vocab/unit" ;
    rdfs:seeAlso "http://www.oxfordreference.com/view/10.1093/acref/9780198605225.001.0001/acref-9780198605225-e-13" ;
    skos:prefLabel "Abfarad"@en ;
    emmo:elucidation """An abfarad is an obsolete electromagnetic (CGS) unit of capacitance equal to 10⁹ farads (1,000,000,000 F or 1 GF). The absolute farad of the e.m.u. system, for a steady current identically abC/abV, and identically reciprocal abdaraf. 1 abF = 1 GF.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/FARAD_Ab" ;
    emmo:ucumCode "GF" ;
    emmo:unitSymbol "abF" ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Abfarad?oldid=407124018" .

