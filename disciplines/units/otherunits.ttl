emmo:InverseSquarePlanckMass a [ a owl:Restriction ;
            owl:hasValue 2.111089e+15 ;
            owl:onProperty emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf ],
        [ a owl:Restriction ;
