    skos:altLabel "BTU per Hour Square Foot"@en ;
    skos:prefLabel "BtuPerHourSquareFoot"@en ;
    emmo:elucidation """`BTU per Hour Square Foot` is an Imperial unit for  'Power Per Area' expressed as Btu/(hr-ft²).

-- QUDT"""@en ;
