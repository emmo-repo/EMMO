    rdfs:isDefinedBy "http://qudt.org/2.1/vocab/unit" ;
    skos:altLabel "Planck Energy"@en ;
    skos:prefLabel "PlanckEnergy"@en ;
    emmo:elucidation """In physics, the unit of energy in the system of natural units known as Planck units is called the Planck energy, denoted by Eₚ. Eₚ is a derived, as opposed to basic, Planck unit. An equivalent definition is: Eₚ = ℏ / tₚ where tₚ is the Planck time. Also: Eₚ = mₚ c² where mₚ is the Planck mass.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/PlanckEnergy" ;
    emmo:unitSymbol "Eᵨ" ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/Planck_energy?oldid=493639955" .

