emmo:Statmho a [ a owl:Restriction ;
            owl:hasValue 1.1126e-12 ;
            owl:onProperty emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf ],
        [ a owl:Restriction ;
            owl:hasValue 0e+00 ;
            owl:onProperty emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd ],
        emmo:EMMO_8246541a_f1f6_4d03_8bd7_fc6b76d17375,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_86ffe1bb_d457_4948_9e39_35f363b9a9fe,
        emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4 ;
    rdfs:isDefinedBy "http://qudt.org/2.1/vocab/unit" ;
    rdfs:seeAlso "http://www.sizes.com/units/statmho.htm" ;
    skos:prefLabel "Statmho"@en ;
    emmo:elucidation """"StatMHO" is the unit of conductance, admittance, and susceptance in the C.G.S e.s.u system of units. One statmho is the conductance between two points in a conductor when a constant potential difference of 1 statvolt applied between the points produces in the conductor a current of 1 statampere, the conductor not being the source of any electromotive force, approximately 1.1126 × 10⁻¹² mho.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/MHO_Stat" ;
    emmo:unitSymbol "stat℧" .

emmo:Statohm a [ a owl:Restriction ;
            owl:hasValue 8.9876e+11 ;
            owl:onProperty emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf ],
        [ a owl:Restriction ;
            owl:hasValue 0e+00 ;
            owl:onProperty emmo:EMMO_d088a3cb_d3e3_4eb2_9897_00aef0cb00cd ],
        emmo:EMMO_7610efb8_c7c6_4684_abc1_774783c62472,
        emmo:EMMO_8246541a_f1f6_4d03_8bd7_fc6b76d17375,
        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4 ;
    rdfs:isDefinedBy "http://qudt.org/2.1/vocab/unit" ;
    rdfs:seeAlso "http://whatis.techtarget.com/definition/statohm-stat-W" ;
    skos:prefLabel "Statohm"@en ;
    emmo:elucidation """"StatOHM" is the unit of resistance, reactance, and impedance in the electrostatic C.G.S system of units, equal to the resistance between two points of a conductor when a constant potential difference of 1 statvolt between these points produces a current of 1 statampere; it is equal to approximately 8.9876 × 10¹¹ ohms. The statohm is an extremely large unit of resistance. In fact, an object with a resistance of 1 stat W would make an excellent insulator or dielectric . In practical applications, the ohm, the kilohm (k W ) and the megohm (M W or M) are most often used to quantify resistance.

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/OHM_Stat" ;
    emmo:unitSymbol "statΩ" .

emmo:Statsiemens a [ a owl:Restriction ;
