        emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4 ;
    rdfs:isDefinedBy "http://qudt.org/2.1/vocab/unit" ;
    skos:altLabel "Degree Baume (US Heavy)"@en ;
    skos:prefLabel "Degree_Baume_Us_Heavy"@en ;
    emmo:elucidation """graduation of the areometer scale for determination of density of fluids according to the Anglo-American system of units, which are heavier than water

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/DEGREE_BAUME_US_HEAVY" ;
    emmo:unitSymbol "°Bé{US Heavy}" .

emmo:Degree_Baume_Us_Light a emmo:EMMO_15344998_4490_4b40_b242_c3d92e5cdc27,
