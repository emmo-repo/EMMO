        emmo:EMMO_868ae137_4d25_493e_b270_21ea3d94849e,
        emmo:EMMO_b081b346_7279_46ef_9a3d_2c088fcd79f4 ;
    rdfs:isDefinedBy "http://qudt.org/2.1/vocab/unit" ;
    skos:prefLabel "Rad"@en ;
    emmo:elucidation """The rad is a deprecated unit of absorbed radiation dose, defined as 1 rad = 0.01 Gy = 0.01 J/kg. It was originally defined in CGS units in 1953 as the dose causing 100 ergs of energy to be absorbed by one gram of matter. It has been replaced by the gray in most of the world. A related unit, the roentgen, was formerly used to quantify the number of rad deposited into a target when it was exposed to radiation. The F-factor can used to convert between rad and roentgens. The material absorbing the radiation can be human tissue or silicon microchips or any other medium (for example, air, water, lead shielding, etc.).

-- QUDT"""@en ;
    emmo:qudtReference "http://qudt.org/vocab/unit/RAD_R" ;
    emmo:ucumCode "RAD" ;
    emmo:unitSymbol "rad" ;
    emmo:wikipediaReference "http://en.wikipedia.org/wiki/RAD?oldid=493716376" .

