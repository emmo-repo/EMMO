emmo:PlanckCharge a [ a owl:Restriction ;
            owl:hasValue 1.875546e-18 ;
            owl:onProperty emmo:EMMO_8189b42e_0995_423a_a26c_51168b27c3cf ],
        [ a owl:Restriction ;
